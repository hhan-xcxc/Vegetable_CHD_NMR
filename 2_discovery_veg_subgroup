# calc correlations
cor_res <- list()

for (s in PPM_select) {
  for (v in food_item2) {
    x <- ana_wk2[[s]]   # ppm
    y <- ana_wk2[[v]]   # foods
    cc <- complete.cases(x, y)
    
    if (sum(cc) > 2) {
      ct <- cor.test(x[cc], y[cc], method = "spearman", exact = FALSE)
      cor_res[[length(cor_res) + 1]] <- data.frame(
        ppm   = s,
        foods  = v,
        method  = "spearman",
        coef    = unname(ct$estimate),
        p_value = ct$p.value,
        n       = sum(cc),
        stringsAsFactors = FALSE
      )
    }
  }
}

