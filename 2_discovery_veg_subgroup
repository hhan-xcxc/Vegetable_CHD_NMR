# function -------------------------------------------------------------------------
# inverse normal transformation
INT<-function(dta,X)
{
  
  for (i in 1:length(X)){
    
    dta[,paste(X[i],"_INT",sep="")]<-qnorm((rank(dta[,X[i]],na.last="keep")-0.5)/sum(!is.na(dta[,X[i]])))
    
  }
  
  return(dta)
  
}

# load dataset -------------------------------------------------------------------------
ana_wk2 <- readRDS("lvs_dataset_area_zscore_osm.rds")

# targeted vegetable groups -------------------------------------------------------------------------
