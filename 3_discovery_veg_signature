# Log(X+ minimum non-zero value/5)
LOG.mini<-function(dta,X)
{
  for (i in 1:length(X)){
    
    mini5<-min(dta[dta[X[i]]>0,X[i]])/5
    dta[,paste(X[i],"_LOG",sep="")]<-log(dta[X[i]]+mini5)
    
  }
  
  return(dta)  
  
}

