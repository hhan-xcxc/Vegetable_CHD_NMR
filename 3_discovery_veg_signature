get_food_beta <- function(nmr_scale_list,
                          veg_var,
                          out_dir = "./Output/",
                          suffix = "_LOG",
                          write_csv = TRUE) {
  # rename
  obj_name <- paste0(veg_var, suffix)
  
  ###
  name_list <- lapply(
    nmr_scale_list,
    function(x) names(x$sp_id[[obj_name]])
  )
  common_ppm <- Reduce(intersect, name_list)
  
  if (length(common_ppm) == 0) {
    stop("No common PPM variables found for ", obj_name)
  }
  
  ###
  beta_mat <- do.call(
    rbind,
    lapply(
      nmr_scale_list,
      function(x) x$sp_id[[obj_name]][, common_ppm, drop = FALSE]
    )
  )
  
  ###
  beta_mean <- colMeans(beta_mat)
  ppm_names <- colnames(beta_mat)
  
  res <- data.frame(
    Betas = as.numeric(beta_mean),
    PPM   = ppm_names,
    row.names = NULL
  )
  
  ### output
  if (write_csv) {
    if (!dir.exists(out_dir)) dir.create(out_dir, recursive = TRUE)
    out_file <- file.path(out_dir,
                          paste0(veg_var, ".eln.score.intake.LOG.csv"))
    write.csv(res, out_file, row.names = FALSE)
  }
  
  return(res)
}


res_list <- lapply(veg_var, get_food_beta,
                   nmr_scale_list = nmr_scale_list)

names(res_list) <- veg_var

calc_scores_from_reslist <- function(data,
                                     res_list,
                                     intake_suffix = "_LOG") {
  
  food_vec <- names(res_list)
  
  score_list <- list()
  cor_res_all <- list()
  
  for (f in food_vec) {
    beta_df <- res_list[[f]]      # data.frame: Betas + PPM
    
    ppm_names <- beta_df$PPM
    betas     <- beta_df$Betas
    
    # calc score
    X <- as.matrix(data[, ppm_names, drop = FALSE])
    score <- as.numeric(X %*% betas)
    score_name <- paste0(f, ".score")
    score_list[[score_name]] <- score
    
    # intake variable
    intake_var <- paste0(f, intake_suffix)
    intake_raw <- f
    
    # calc correlation
    pear.log  <- cor.test(data[[intake_var]], score, method = "pearson")
    pear.raw  <- cor.test(data[[intake_raw]], score, method = "pearson")
    spear.raw <- cor.test(data[[intake_raw]], score, method = "spearman", exact = FALSE)
    
    cor_res_all[[f]] <- data.frame(
      food          = f,
      pearson.coef.log  = as.numeric(pear.log$estimate),
      pearson.p.log     = pear.log$p.value,
      pearson.coef.raw  = as.numeric(pear.raw$estimate),
      pearson.p.raw     = pear.raw$p.value,
      spearman.coef.raw = as.numeric(spear.raw$estimate),
      spearman.p.raw    = spear.raw$p.value,
      stringsAsFactors = FALSE
    )
  }
  
  score_df <- as.data.frame(score_list)
  
  if (length(cor_res_all) > 0) {
    cor_df <- do.call(rbind, cor_res_all)
    rownames(cor_df) <- NULL
  } else {
    cor_df <- data.frame()
  }
  
  list(
    scores = score_df,  
    cor    = cor_df    
  )
}
