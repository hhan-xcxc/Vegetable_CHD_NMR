# fixed-effect model
run_meta_all <- function(data1, data2, data3) {
  
  data1$Cohort <- "NHS1"
  data2$Cohort <- "NHS2"
  data3$Cohort <- "SOL"
  
  all_res <- bind_rows(data1, data2, data3)
  
  run_meta <- function(df, term_prefix) {
    metafor::rma(
      yi = df[[paste0(term_prefix, "_logOR")]],
      sei = df[[paste0(term_prefix, "_SE")]],
      method = "FE"
    )
  }
  
  extract_meta <- function(m) {
    or <- exp(m$b)
    ci <- exp(c(m$ci.lb, m$ci.ub))
    tibble(
      logOR = as.numeric(m$b),
      SE = m$se,
      P = m$pval,
      OR = as.numeric(or),
      CI_lower = ci[1],
      CI_upper = ci[2]
    )
  }
  
  meta_terms <- c("Q2", "Q3", "Q4", "trend", "z")
  
  meta_results <- all_res %>%
    group_by(Feature, Model) %>%
    group_split() %>%  
    map_dfr(function(df) {
      feature <- unique(df$Feature)
      model <- unique(df$Model)
      
      map_dfr(meta_terms, function(term) {
        model_fit <- tryCatch(run_meta(df, term), error = function(e) NULL)
        if (!is.null(model_fit)) {
          result <- extract_meta(model_fit)
          result$Term <- term
        } else {
          result <- tibble(
            Term = term, logOR = NA, SE = NA, P = NA,
            OR = NA, CI_lower = NA, CI_upper = NA
          )
        }
        result
      }) %>%
        mutate(Feature = feature, Model = model) %>%
        dplyr::select(Feature, Model, Term, everything())
    })
  
  return(meta_results)
}

# format
add_formatted_column <- function(df) {
  df %>%
    mutate(format = case_when(
      Term %in% c("Q2", "Q3", "Q4", "z") ~ sprintf("%.2f (%.2f, %.2f)", OR, CI_lower, CI_upper),
      Term == "trend" ~ as.character(P),
      TRUE ~ NA_character_
    ))
}

