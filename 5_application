models_nmr <- list()
for (met_score in veg_list) {
  
  fea_col  <- paste0(met_score, "q")      # quartile
  mfea_col <- paste0("m", met_score, "q") # p-trend
  z_col    <- paste0(met_score, "z")      # per 1-SD
  
  # model 0: adjusting for matching factors
  models_nmr[[paste0("fit_m0_", met_score, "_q4")]] <- clogit(mi ~ factor(data.caco[[fea_col]]) + strata(pair), 
                                                              data = data.caco)
  models_nmr[[paste0("fit_m0_", met_score, "_tr")]] <- clogit(mi ~ data.caco[[mfea_col]] + strata(pair), 
                                                              data = data.caco)
  models_nmr[[paste0("fit_m0_", met_score, "_z")]]  <- clogit(mi ~ data.caco[[z_col]] + strata(pair), 
                                                              data = data.caco) 
  
  # model 1
  models_nmr[[paste0("fit_m1_", met_score, "_q4")]] <- clogit(as.formula(paste0("mi ~ factor(data.caco[['", fea_col, "']]) + strata(pair) + ", 
                                                                                paste(cov_m1_list, collapse = " + "))), data = data.caco)
  models_nmr[[paste0("fit_m1_", met_score, "_tr")]] <- clogit(as.formula(paste0("mi ~ data.caco[['", mfea_col, "']] + strata(pair) + ", 
                                                                                paste(cov_m1_list, collapse = " + "))), data = data.caco)
  models_nmr[[paste0("fit_m1_", met_score, "_z")]] <- clogit(as.formula(paste0("mi ~ data.caco[['", z_col, "']] + strata(pair) + ", 
                                                                               paste(cov_m1_list, collapse = " + "))), data = data.caco)
  
  # model 2
  models_nmr[[paste0("fit_m2_", met_score, "_q4")]] <- clogit(as.formula(paste0("mi ~ factor(data.caco[['", fea_col, "']]) + strata(pair) + ", 
                                                                                paste(cov_m2_list, collapse = " + "))), data = data.caco)
  models_nmr[[paste0("fit_m2_", met_score, "_tr")]] <- clogit(as.formula(paste0("mi ~ data.caco[['", mfea_col, "']] + strata(pair) + ", 
                                                                                paste(cov_m2_list, collapse = " + "))), data = data.caco)
  models_nmr[[paste0("fit_m2_", met_score, "_z")]] <- clogit(as.formula(paste0("mi ~ data.caco[['", z_col, "']] + strata(pair) + ", 
                                                                               paste(cov_m2_list, collapse = " + "))), data = data.caco)
}

