### met_score ###
results <- list()
for (met_score in veg_list) {
  row_list <- list()
  
  for (m in 0:2) {
    model_tag <- paste0("model", m)
    prefix <- paste0("fit_m", m, "_", met_score)
    
    # Q4 
    fit_q4 <- models_nmr[[paste0(prefix, "_q4")]]
    q4_coef <- coef(fit_q4)[1:3]
    q4_conf <- confint(fit_q4)[1:3, ]
    q4_summary <- summary(fit_q4)$coefficients[1:3, ]
    
    q_or <- as.data.frame(round(cbind(
      OR = exp(q4_coef),
      LowerCI = exp(q4_conf[, 1]),
      UpperCI = exp(q4_conf[, 2])
    ), 2))
    
    # OR(95%CI)
    q2_str <- paste0(q_or$OR[1], " (", q_or$LowerCI[1], ", ", q_or$UpperCI[1], ")")
    q3_str <- paste0(q_or$OR[2], " (", q_or$LowerCI[2], ", ", q_or$UpperCI[2], ")")
    q4_str <- paste0(q_or$OR[3], " (", q_or$LowerCI[3], ", ", q_or$UpperCI[3], ")")
    
    # logOR / SE / P
    q2_logOR <- round(q4_coef[1], 4); q2_se <- round(q4_summary[1, "se(coef)"], 4); q2_p <- round(q4_summary[1, "Pr(>|z|)"], 4)
    q3_logOR <- round(q4_coef[2], 4); q3_se <- round(q4_summary[2, "se(coef)"], 4); q3_p <- round(q4_summary[2, "Pr(>|z|)"], 4)
    q4_logOR <- round(q4_coef[3], 4); q4_se <- round(q4_summary[3, "se(coef)"], 4); q4_p <- round(q4_summary[3, "Pr(>|z|)"], 4)
    
    # trend
    fit_tr <- models_nmr[[paste0(prefix, "_tr")]]
    tr_sum <- summary(fit_tr)$coefficients[1, ]
    p_trend <- round(tr_sum["Pr(>|z|)"], 4)
    logOR_trend <- round(tr_sum["coef"], 4)
    se_trend <- round(tr_sum["se(coef)"], 4)
    
    # z-score
    fit_z <- models_nmr[[paste0(prefix, "_z")]]
    z_sum <- summary(fit_z)$coefficients[1, ]
    logOR_z <- round(z_sum["coef"], 4)
    se_z <- round(z_sum["se(coef)"], 4)
    p_z <- round(z_sum["Pr(>|z|)"], 4)
    or_z <- round(exp(logOR_z), 2)
    ci_lower_z <- round(exp(logOR_z - 1.96 * se_z), 2)
    ci_upper_z <- round(exp(logOR_z + 1.96 * se_z), 2)
    perSD_str <- paste0(or_z, " (", ci_lower_z, ", ", ci_upper_z, ")")
    
    # summary
    row_list[[m + 1]] <- data.frame(
      Feature = met_score,
      Model = model_tag,
      
      Q2 = q2_str,
      Q2_logOR = q2_logOR,
      Q2_SE = q2_se,
      Q2_P = q2_p,
      
      Q3 = q3_str,
      Q3_logOR = q3_logOR,
      Q3_SE = q3_se,
      Q3_P = q3_p,
      
      Q4 = q4_str,
      Q4_logOR = q4_logOR,
      Q4_SE = q4_se,
      Q4_P = q4_p,
      
      P_trend = p_trend,
      logOR_trend = logOR_trend,
      SE_trend = se_trend,
      
      PerSD = perSD_str,
      logOR_z = logOR_z,
      SE_z = se_z,
      P_z = p_z,
      
      stringsAsFactors = FALSE
    )
  }
  
  results[[met_score]] <- do.call(rbind, row_list)
}

cohortA_res_veg <- do.call(rbind, results)


