# based on distribution among controls
makequantiles_ctr <- function(var, dataframe, cutoffs, ret, caco_col) {
  
  subset_data <- dataframe[dataframe[[caco_col]] == 0, ] # control
  var_subset <- subset_data[[var]]  
  
  var_all <- dataframe[[var]]  
  quant <- rep(NA, length(var_all))
  
  if(cutoffs == 2) {
    thresholds <- quantile(var_subset, probs = c(0.5), na.rm = TRUE)
    quant[!is.na(var_all) & var_all < thresholds[1]] <- 1
    quant[!is.na(var_all) & var_all >= thresholds[1]] <- 2
    
  } else if(cutoffs == 3) {
    thresholds <- quantile(var_subset, probs = c(0.33, 0.67), na.rm = TRUE)
    quant[!is.na(var_all) & var_all < thresholds[1]] <- 1
    quant[!is.na(var_all) & var_all >= thresholds[1] & var_all < thresholds[2]] <- 2
    quant[!is.na(var_all) & var_all >= thresholds[2]] <- 3
    
  } else if(cutoffs == 4) {
    thresholds <- quantile(var_subset, probs = c(0.25, 0.5, 0.75), na.rm = TRUE)
    quant[!is.na(var_all) & var_all < thresholds[1]] <- 1
    quant[!is.na(var_all) & var_all >= thresholds[1] & var_all < thresholds[2]] <- 2
    quant[!is.na(var_all) & var_all >= thresholds[2] & var_all < thresholds[3]] <- 3
    quant[!is.na(var_all) & var_all >= thresholds[3]] <- 4
    
  } else if(cutoffs == 5) {
    thresholds <- quantile(var_subset, probs = seq(0.2, 0.8, by = 0.2), na.rm = TRUE)
    quant[!is.na(var_all) & var_all < thresholds[1]] <- 1
    quant[!is.na(var_all) & var_all >= thresholds[1] & var_all < thresholds[2]] <- 2
    quant[!is.na(var_all) & var_all >= thresholds[2] & var_all < thresholds[3]] <- 3
    quant[!is.na(var_all) & var_all >= thresholds[3] & var_all < thresholds[4]] <- 4
    quant[!is.na(var_all) & var_all >= thresholds[4]] <- 5
    
  } else if(cutoffs == 10) {
    thresholds <- quantile(var_subset, probs = seq(0.1, 0.9, by = 0.1), na.rm = TRUE)
    for(i in 1:10) {
      if(i == 1) {
        quant[!is.na(var_all) & var_all < thresholds[i]] <- i
      } else if(i == 10) {
        quant[!is.na(var_all) & var_all >= thresholds[i-1]] <- i
      } else {
        quant[!is.na(var_all) & var_all >= thresholds[i-1] & var_all < thresholds[i]] <- i
      }
    }
  }
  
  if(ret == "quant") {
    if(length(unique(quant)) < cutoffs) {
      quantx <- quant
      values <- unique(quantx[!is.na(quantx)])
      for(i in seq_along(values)) {
        quant[quantx == values[i]] <- i
      }
    }
    return(quant)
  } else if(ret == "median") {
    median_vals <- rep(NA, length(var_all))
    for(i in 1:cutoffs) {
      median_vals[quant == i] <- median(var_all[quant == i], na.rm = TRUE)
    }
    return(median_vals)
  }
}

makezscore_ctr <- function(var, dataframe, caco_col) {
  
  subset_data <- dataframe[dataframe[[caco_col]] == 0, ]
  var_ctrl <- subset_data[[var]]
  
  mean_ctrl <- mean(var_ctrl, na.rm = TRUE)
  sd_ctrl <- sd(var_ctrl, na.rm = TRUE)
  
  var_all <- dataframe[[var]]
  
  z_score <- (var_all - mean_ctrl) / sd_ctrl
  
  return(z_score)
}

